---
interface Props {
  title: string;
  description: string;
  pageCSS: string;
  activeNav?: string;
}

const { title, description, pageCSS, activeNav } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />

  <!-- Styles -->
  <link rel="stylesheet" href={`${base}css/tokens.css`} />
  <link rel="stylesheet" href={`${base}css/reset.css`} />
  <link rel="stylesheet" href={`${base}css/global.css`} />
  <link rel="stylesheet" href={`${base}css/pages/${pageCSS}`} />
</head>
<body>

  <!-- ══════════════════════════════════════════════
       HEADER
  ══════════════════════════════════════════════ -->
  <header class="site-header">
    <div class="container">
      <div class="header-inner">

        <!-- Logo -->
        <a href={base} class="header-logo" aria-label="Hermanos Energy - Home">
          <img src={`${base}assets/images/Hermanos-Logo-Green.svg`} alt="Hermanos Energy" />
        </a>

        <!-- Desktop nav -->
        <nav class="header-nav" aria-label="Main navigation">
          <a href={`${base}product`} data-i18n="nav.product" class={activeNav === 'product' ? 'active' : ''}>Product</a>
          <a href={`${base}aboutus`} data-i18n="nav.about" class={activeNav === 'about' ? 'active' : ''}>About Us</a>
          <a href={`${base}contact`} data-i18n="nav.contact" class={activeNav === 'contact' ? 'active' : ''}>Contact Us</a>

          <!-- Language switcher -->
          <div class="lang-switcher" aria-label="Language">
            <button data-lang-btn="en" onclick="I18n.switch('en')">EN</button>
            <span class="lang-switcher-divider" aria-hidden="true"></span>
            <button data-lang-btn="nl" onclick="I18n.switch('nl')">NL</button>
          </div>

          <!-- CTA -->
          <a href="https://www.hermanos.energy/" target="_blank" rel="noopener" class="btn-sign-in" data-i18n="nav.sign_in">Sign in</a>
        </nav>

        <!-- Hamburger (mobile) -->
        <button class="hamburger" aria-label="Open menu" aria-expanded="false" aria-controls="mobile-nav">
          <span></span>
          <span></span>
          <span></span>
        </button>

      </div>
    </div>

    <!-- Mobile nav drawer -->
    <nav class="mobile-nav" id="mobile-nav" aria-label="Mobile navigation">
      <a href={`${base}product`} data-i18n="nav.product">Product</a>
      <a href={`${base}aboutus`} data-i18n="nav.about">About Us</a>
      <a href={`${base}contact`} data-i18n="nav.contact">Contact Us</a>
      <a href="https://www.hermanos.energy/" target="_blank" rel="noopener" class="btn-sign-in" data-i18n="nav.sign_in" style="align-self:flex-start; margin-top: var(--space-2);">Sign in</a>

      <div class="lang-switcher" aria-label="Language">
        <button data-lang-btn="en" onclick="I18n.switch('en')">EN</button>
        <span class="lang-switcher-divider" aria-hidden="true"></span>
        <button data-lang-btn="nl" onclick="I18n.switch('nl')">NL</button>
      </div>
    </nav>
  </header>


  <!-- ══════════════════════════════════════════════
       PAGE CONTENT
  ══════════════════════════════════════════════ -->
  <main class="page-content">
    <slot />
  </main>


  <!-- ══════════════════════════════════════════════
       FOOTER
  ══════════════════════════════════════════════ -->
  <footer class="site-footer">
    <div class="footer-inner">

      <!-- Logo -->
      <a href={base} class="footer-logo" aria-label="Hermanos Energy - Home">
        <img src={`${base}assets/images/Hermanos-Logo-Green.svg`} alt="Hermanos Energy" />
      </a>

      <!-- Nav links -->
      <nav class="footer-nav" aria-label="Footer navigation">
        <a href={`${base}product`} data-i18n="nav.product">Product</a>
        <a href={`${base}aboutus`} data-i18n="nav.about">About Us</a>
        <a href={`${base}contact`} data-i18n="nav.contact">Contact Us</a>
      </nav>

      <!-- Address + copyright -->
      <div class="footer-address">
        <p data-i18n-html="footer.address">Address: Transistorstraat 151, 1322 CN Almere<br />Kvk nummer 91848946</p>
        <p data-i18n="footer.copyright">Hermanos Energy 2025 © All rights reserved</p>
      </div>

    </div>
  </footer>


  <!-- Scripts -->
  <script src={`${base}js/i18n.js`}></script>
  <script src={`${base}js/main.js`}></script>

</body>
</html>
