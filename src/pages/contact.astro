---
import Layout from '../layouts/Layout.astro';
const base = import.meta.env.BASE_URL;
---

<Layout
  title="Contact — Hermanos Energy"
  description="Get in touch with Hermanos Energy. Book a demo or ask for custom energy advice."
  pageCSS="contact.css"
  activeNav="contact"
>

  <!-- ══════════════════════════════════════════════
       MAIN SECTION
  ══════════════════════════════════════════════ -->
  <section class="ct-main">
    <div class="container">

      <!-- Hero text -->
      <div class="ct-hero">
        <p class="ct-label" data-i18n="contact.hero.label">contact us</p>
        <h1 class="ct-title" data-i18n="contact.hero.title">Get in touch</h1>
        <p class="ct-description" data-i18n="contact.hero.description">If your interested in the product, or want to learn more feel free to contact us for a demo. If you want to know if the product is for you then we will start by doing a detailed calculation of which hardware solution fits with your energy setup at home.</p>
      </div>

      <!-- Content: form + info -->
      <div class="ct-content">

        <!-- Form -->
        <div class="ct-form-wrap">
          <form class="ct-form" method="POST" action="#">
            <div class="ct-form-row">
              <input class="ct-input" type="text" name="name" placeholder="Name" data-i18n-placeholder="contact.form.name" required />
              <input class="ct-input" type="email" name="email" placeholder="Email" data-i18n-placeholder="contact.form.email" required />
            </div>
            <textarea class="ct-input ct-textarea" name="message" placeholder="Message" data-i18n-placeholder="contact.form.message" required></textarea>
            <button class="ct-submit" type="submit" data-i18n="contact.form.submit">Send Message</button>
          </form>
        </div>

        <!-- Info: address + social -->
        <div class="ct-info">

          <!-- Address card -->
          <div class="ct-address-card">
            <div class="ct-address-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z" fill="currentColor"/>
              </svg>
            </div>
            <div class="ct-address-body">
              <p class="ct-address-city" data-i18n="contact.address.city">Almere</p>
              <p class="ct-address-street" data-i18n="contact.address.street">Transistorstraat 151<br>1322 CN Almere<br>The Netherlands</p>
            </div>
          </div>

          <!-- Connect -->
          <div class="ct-connect">
            <p class="ct-connect-label" data-i18n="contact.connect.label">CONNECT WITH US</p>
            <a href="https://www.linkedin.com/company/hermanos-energy/" class="ct-linkedin" target="_blank" rel="noopener noreferrer" aria-label="Hermanos Energy on LinkedIn">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
              </svg>
              <span data-i18n="contact.connect.linkedin">Hermanos Energy on LinkedIn</span>
            </a>
          </div>

        </div>
      </div>

    </div>
  </section>

</Layout>
