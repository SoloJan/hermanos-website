---
import Layout from '../layouts/Layout.astro';
const base = import.meta.env.BASE_URL;
---

<Layout
  title="Hermanos Energy"
  description="Hermanos Energy is dedicated to providing cutting-edge solutions for energy storage using hydrogen technology."
  pageCSS="home.css"
>

  <!-- ══════════════════════════════════════════════
       HERO
  ══════════════════════════════════════════════ -->
  <section class="hero">
    <div class="hero-bg">
      <img src={`${base}assets/images/hero-background.avif`} alt="" />
    </div>
    <div class="hero-content">
      <h1 class="hero-title" data-i18n="home.hero.title">Endless clean energy.</h1>
      <p class="hero-subtitle" data-i18n="home.hero.subtitle">We are dedicated to providing cutting-edge solutions for energy storage using hydrogen technology.</p>
      <a href={`${base}contact`} class="btn-contact" data-i18n="home.hero.cta">Contact us</a>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════
       INTRO — Looking to the future
  ══════════════════════════════════════════════ -->
  <section class="intro-future">
    <div class="intro-row">

      <div class="intro-text">
        <h2 class="section-heading">Looking to the future.</h2>
        <p class="section-body">Renewable energy sources like wind power, and solar are increasing rapidly but to balance the energy grid and secure a stable power supply, the world is still counting on fossil fuel as a energy source. A year-round stable power supply without fossil fuels can only be achieved with local energy storage.</p>
      </div>

      <div class="intro-photo">
        <img src={`${base}assets/images/intro-photo-1.avif`} alt="Hydrogen energy installation with solar panels" />
      </div>

    </div>
  </section>

  <!-- ══════════════════════════════════════════════
       INTRO — You can help
  ══════════════════════════════════════════════ -->
  <section class="intro-help">
    <div class="intro-row">

      <div class="intro-charts">
        <img src={`${base}assets/images/intro-photo-2.avif`} alt="Chart: Typical electricity prices" class="chart-image" />
        <img src={`${base}assets/images/intro-photo-3.avif`} alt="Chart: Solar and wind electricity on the grid" class="chart-image" />
      </div>

      <div class="intro-text">
        <h2 class="section-heading">You can help and benefit from the energy transition.</h2>
        <p class="section-body">On windy and sunny periods during the day the green energy supply exceeds the demand which is leading to very low prices, and sometimes even free electricity. Green energy is cheap energy! With the energy storage of Hermanos Energy you can benefit from the daily and seasonal price difference and contribute to net zero at the same time.</p>
      </div>

    </div>
  </section>

  <!-- ══════════════════════════════════════════════
       ONE VISION. THREE PRODUCTS.
  ══════════════════════════════════════════════ -->
  <section class="products">
    <div class="products-inner">

      <div class="products-heading">
        <h2 class="section-heading section-heading--light">One vision. Three products.</h2>
        <p class="section-body section-body--light">It is our mission to use the abundance of green energy to replace fossil fuels wherever they are used. We always produce the hydrogen locally, at your home or business, and it can be used in various ways.</p>
      </div>

      <div class="products-cards">

        <div class="product-card">
          <div class="product-card-icon">
            <img src={`${base}assets/images/icon-power-to-heat.svg`} alt="" />
          </div>
          <p class="product-card-text">Using your summer sun to heat in the winter, with power to heat.</p>
        </div>

        <div class="product-card">
          <div class="product-card-icon">
            <img src={`${base}assets/images/icon-power-to-power.svg`} alt="" />
          </div>
          <p class="product-card-text">All year round green electricyty with power to power.</p>
        </div>

        <div class="product-card">
          <div class="product-card-icon">
            <img src={`${base}assets/images/icon-power-to-drive.svg`} alt="" />
          </div>
          <p class="product-card-text">Driving a vehicle on hydrogen. With power to drive.</p>
        </div>

      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════
       EMS
  ══════════════════════════════════════════════ -->
  <section class="ems">
    <div class="ems-inner">

      <div class="ems-content">
        <div class="ems-text">
          <p class="ems-label">Our OWN EMS</p>
          <h2 class="ems-heading">The software behind it all.</h2>
          <p class="ems-body">Green energy is all about timing, we make hydrogen when there is an abundance of green cheap electricity, and use it when you need it most, our software takes care of that.</p>
        </div>
        <ul class="ems-list">
          <li class="ems-list-item">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 256 256" class="ems-check-icon" aria-hidden="true"><path d="M128,24A104,104,0,1,0,232,128,104.2,104.2,0,0,0,128,24Zm49.5,85.8-58.6,56a8.1,8.1,0,0,1-5.6,2.2,7.7,7.7,0,0,1-5.5-2.2l-29.3-28a8,8,0,1,1,11-11.6l23.8,22.7,53.2-50.7a8,8,0,0,1,11,11.6Z"/></svg>
            <span>Makes predictions based on your historical data, and the weather</span>
          </li>
          <li class="ems-list-item">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 256 256" class="ems-check-icon" aria-hidden="true"><path d="M128,24A104,104,0,1,0,232,128,104.2,104.2,0,0,0,128,24Zm49.5,85.8-58.6,56a8.1,8.1,0,0,1-5.6,2.2,7.7,7.7,0,0,1-5.5-2.2l-29.3-28a8,8,0,1,1,11-11.6l23.8,22.7,53.2-50.7a8,8,0,0,1,11,11.6Z"/></svg>
            <span>Live connected to your solar panels and consumption.</span>
          </li>
          <li class="ems-list-item">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 256 256" class="ems-check-icon" aria-hidden="true"><path d="M128,24A104,104,0,1,0,232,128,104.2,104.2,0,0,0,128,24Zm49.5,85.8-58.6,56a8.1,8.1,0,0,1-5.6,2.2,7.7,7.7,0,0,1-5.5-2.2l-29.3-28a8,8,0,1,1,11-11.6l23.8,22.7,53.2-50.7a8,8,0,0,1,11,11.6Z"/></svg>
            <span>Can scale up and down in milliseconds</span>
          </li>
          <li class="ems-list-item">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 256 256" class="ems-check-icon" aria-hidden="true"><path d="M128,24A104,104,0,1,0,232,128,104.2,104.2,0,0,0,128,24Zm49.5,85.8-58.6,56a8.1,8.1,0,0,1-5.6,2.2,7.7,7.7,0,0,1-5.5-2.2l-29.3-28a8,8,0,1,1,11-11.6l23.8,22.7,53.2-50.7a8,8,0,0,1,11,11.6Z"/></svg>
            <span>Picks the right moments based on day ahead prices</span>
          </li>
        </ul>
      </div>

      <div class="ems-image">
        <img src={`${base}assets/images/bg-gradient-4.webp`} alt="" />
      </div>

    </div>
  </section>

  <!-- ══════════════════════════════════════════════
       CTA — Get in touch
  ══════════════════════════════════════════════ -->
  <section class="cta">
    <div class="cta-inner">

      <div class="cta-content">
        <p class="cta-label">Book a demo, or ask for custom energy advice</p>
        <h2 class="cta-heading">Get in touch.</h2>
        <a href={`${base}contact`} class="btn-contact">Contact us</a>
      </div>

      <div class="cta-image">
        <img src={`${base}assets/images/cta-preview.avif`} alt="Website examples" />
      </div>

    </div>
  </section>

</Layout>
